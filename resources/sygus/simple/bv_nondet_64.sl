(set-logic BV)

(synth-fun f ((x (_ BitVec 64))) (_ BitVec 64)
    ((Start (_ BitVec 64)))
    ((Start (_ BitVec 64) (
        (bvand Start Start)
        (bvor  Start Start)
        (bvxor Start Start)
        (bvsub Start Start)
        (bvshl Start Start)
        (bvlshr Start Start)
        (bvashr Start Start)
        #x0000000000000001
        x
        ))))

(declare-var x (_ BitVec 64))
(constraint
    (ite
        (or (= x #x0000000000000000)
        (or (= x #x0000000000000001)
        (or (= x #x0000000000000002)
        (or (= x #x0000000000000004) 
        (or (= x #x0000000000000008) 
        (or (= x #x0000000000000010)
        (or (= x #x0000000000000020)
        (or (= x #x0000000000000040) 
        (or (= x #x0000000000000080) 
        (or (= x #x0000000000000100)
        (or (= x #x0000000000000200)
        (or (= x #x0000000000000400) 
        (or (= x #x0000000000000800) 
        (or (= x #x0000000000001000)
        (or (= x #x0000000000002000)
        (or (= x #x0000000000004000) 
        (or (= x #x0000000000008000) 
        (or (= x #x0000000000010000)
        (or (= x #x0000000000020000)
        (or (= x #x0000000000040000) 
        (or (= x #x0000000000080000) 
        (or (= x #x0000000000100000)
        (or (= x #x0000000000200000)
        (or (= x #x0000000000400000) 
        (or (= x #x0000000000800000) 
        (or (= x #x0000000001000000)
        (or (= x #x0000000002000000)
        (or (= x #x0000000004000000) 
        (or (= x #x0000000008000000) 
        (or (= x #x0000000010000000)
        (or (= x #x0000000020000000)
        (or (= x #x0000000040000000) 
        (or (= x #x0000000080000000) 
        (or (= x #x0000000000000000)
        (or (= x #x0000000100000000)
        (or (= x #x0000000200000000)
        (or (= x #x0000000400000000) 
        (or (= x #x0000000800000000) 
        (or (= x #x0000001000000000)
        (or (= x #x0000002000000000)
        (or (= x #x0000004000000000) 
        (or (= x #x0000008000000000) 
        (or (= x #x0000010000000000)
        (or (= x #x0000020000000000)
        (or (= x #x0000040000000000) 
        (or (= x #x0000080000000000) 
        (or (= x #x0000100000000000)
        (or (= x #x0000200000000000)
        (or (= x #x0000400000000000) 
        (or (= x #x0000800000000000) 
        (or (= x #x0001000000000000)
        (or (= x #x0002000000000000)
        (or (= x #x0004000000000000) 
        (or (= x #x0008000000000000) 
        (or (= x #x0010000000000000)
        (or (= x #x0020000000000000)
        (or (= x #x0040000000000000) 
        (or (= x #x0080000000000000) 
        (or (= x #x0100000000000000)
        (or (= x #x0200000000000000)
        (or (= x #x0400000000000000) 
        (or (= x #x0800000000000000) 
        (or (= x #x1000000000000000)
        (or (= x #x2000000000000000)
        (or (= x #x4000000000000000) 
            (= x #x8000000000000000) 
	)))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))))
        (= (f x) #x0000000000000000)
        (not (= (f x) #x0000000000000000)))
)

(check-synth)

